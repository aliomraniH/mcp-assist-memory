# assist-memory — environment configuration (Phase 0, Postgres backend).
#
# In production these live in Replit Secrets and are read ONLY through
# src/assist_memory/config.py. Never commit real secret values.

# --- Required ---

# Postgres connection string (Neon / Replit managed). Holds BOTH the MCP memory
# (memory_entry, session, artifact_blob, ...) and the admin token table
# (admin_auth_tokens). Use the POOLED (PgBouncer) endpoint; server-side prepared
# statements are disabled in code (prepare_threshold=None) for transaction
# pooling. On Replit's managed Postgres this and the PG* vars are provided
# automatically — do not set them by hand.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Password gate for the /admin dashboard (token view + rotation). Without it the
# dashboard refuses logins. Set a strong value.
ADMIN_PASSWORD=change-me

# --- Optional ---

# Seeds the FIRST auth token on initial boot so an existing client registration
# keeps working; afterward the live token is owned by the /admin dashboard and
# this is ignored. Leave unset to auto-generate the first token.
# MCP_AUTH_TOKEN=

# Secret used to sign /admin session cookies. Falls back to ADMIN_PASSWORD, then
# to a per-process random value. Set explicitly if you run more than one process.
# SESSION_SECRET=

# --- Limits ---

# Per-blob bytea write cap (defense-in-depth against VM OOM). MVP = 25 MB.
# MAX_ARTIFACT_BYTES=26214400
# MAX_UPLOAD_MB=25
# MAX_TOTAL_STORAGE_MB=500

# --- Server ---

# PORT=8000
# LOG_LEVEL=INFO

# --- Phase 3 (declared now, UNUSED until embeddings/recall land) ---
# VOYAGE_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# LANGSMITH_API_KEY=
