# assist-memory — environment configuration (Phase 0, Postgres backend).
#
# In production these live in Replit Secrets and are read ONLY through
# src/assist_memory/config.py. Never commit real secret values.

# --- Required ---

# Neon Postgres connection string. Use the POOLED (PgBouncer) endpoint for the
# running service. Because PgBouncer uses transaction pooling, server-side
# prepared statements are disabled in code (prepare_threshold=None).
#   Runtime/read role:  least privilege for the app process.
#   Owner/migrator role: used by `make migrate` to apply migrations/0001_init.sql.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Bearer token required on /mcp (Authorization: Bearer <token>, or ?token=<token>
# for headerless clients such as the claude.ai web connector).
MCP_AUTH_TOKEN=change-me

# --- Limits ---

# Per-blob bytea write cap (defense-in-depth against VM OOM). MVP = 25 MB.
# MAX_ARTIFACT_BYTES=26214400
# MAX_UPLOAD_MB=25
# MAX_TOTAL_STORAGE_MB=500

# --- Server ---

# PORT=8000
# LOG_LEVEL=INFO

# --- Phase 3 (declared now, UNUSED until embeddings/recall land) ---
# VOYAGE_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# LANGSMITH_API_KEY=
