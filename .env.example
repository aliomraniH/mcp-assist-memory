# Copy to .env (local) or set these in Replit Secrets. Read ONLY by config.py.

# --- required ---
# Postgres POOLED endpoint (e.g. Neon PgBouncer: note the -pooler host and
# sslmode=require). Holds the memory tables and the admin token table.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require
# Seeds the "web" surface token (claude.ai connector) on initial boot; the
# "desktop-cli" token (Claude Desktop + Claude Code CLI) is auto-generated.
# Afterward both tokens are owned by the /admin dashboard — one card per surface,
# rotate each independently. Clients present a token on /mcp (Bearer header, or
# ?token= for the headerless web connector).
MCP_AUTH_TOKEN=change-me-long-random

# --- admin dashboard (/admin) ---
# Password gate for the token dashboard; without it the dashboard refuses logins.
ADMIN_PASSWORD=change-me-admin
# Optional: signs the /admin session cookie (falls back to ADMIN_PASSWORD, then
# a per-process random value).
# SESSION_SECRET=

# --- semantic recall (Phase 3) — service boots & works WITHOUT these ---
# Set VOYAGE_API_KEY to embed memory entries (Voyage) and rank memory_search by
# meaning. Without it, search degrades to keyword/substring (no behavior break).
# After setting it on an existing DB, backfill once: python scripts/backfill_embeddings.py
# VOYAGE_API_KEY=
# EMBEDDING_MODEL=voyage-3.5-lite   # default; EMBEDDING_DIM must match vector(N) in migrations/0002
# EMBEDDING_DIM=1024
# OPENAI_API_KEY=          # other tiers (CLI critic); NOT used for embeddings
# ANTHROPIC_API_KEY=
# LANGSMITH_API_KEY=

# --- optional overrides (defaults shown) ---
# MAX_ARTIFACT_BYTES=52428800     # 50 MB
# PORT=8000
