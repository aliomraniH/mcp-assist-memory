modules = ["python-3.11", "postgresql-16"]
# The service entrypoint is the FastAPI app (app.py); there is no main.py.
run = ["sh", "-c", "python scripts/migrate.py && uvicorn app:app --host 0.0.0.0 --port 5000"]
entrypoint = "app.py"

[deployment]
run = ["sh", "-c", "python scripts/migrate.py && uvicorn app:app --host 0.0.0.0 --port ${PORT:-8000}"]
deploymentTarget = "vm"
build = ["sh", "-c", "pip install -e ."]

[nix]
channel = "stable-25_05"
packages = ["postgresql"]

[agent]
expertMode = true
integrations = ["github:1.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python scripts/migrate.py && uvicorn app:app --host 0.0.0.0 --port 5000"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[postMerge]
path = "post-merge.sh"
timeoutMs = 180000
